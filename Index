<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edson Martins - Currículo Profissional</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Roboto, 'Open Sans', Calibri, Arial, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            display: flex;
            justify-content: center;
            padding: 40px 20px;
            line-height: 1.6;
            color: #2c3e50;
        }

        .container {
            max-width: 1000px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        /* Header com gradiente profissional */
        .header {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 40px;
            position: relative;
        }

        .header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #00d2ff, #3a7bd5);
        }

        .name {
            font-size: 2.5em;
            font-weight: 600;
            margin-bottom: 10px;
            letter-spacing: 1px;
        }

        .title {
            font-size: 1.2em;
            opacity: 0.9;
            margin-bottom: 20px;
            font-weight: 400;
        }

        .contact-info {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            background: rgba(255, 255, 255, 0.1);
            padding: 15px 20px;
            border-radius: 10px;
            margin-top: 15px;
        }

        .contact-info div {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .contact-info i {
            font-style: normal;
            font-weight: 600;
        }

        .linkedin-link {
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: opacity 0.3s;
        }

        .linkedin-link:hover {
            opacity: 0.8;
            text-decoration: underline;
        }

        /* Conteúdo principal */
        .content {
            padding: 40px;
        }

        /* Seções */
        .section {
            margin-bottom: 35px;
        }

        .section-title {
            font-size: 1.5em;
            font-weight: 600;
            color: #1e3c72;
            margin-bottom: 20px;
            padding-bottom: 8px;
            border-bottom: 3px solid #2a5298;
            position: relative;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -3px;
            left: 0;
            width: 50px;
            height: 3px;
            background: #00d2ff;
        }

        /* Experiência profissional */
        .experience-item {
            margin-bottom: 30px;
        }

        .experience-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }

        .company {
            font-size: 1.2em;
            font-weight: 600;
            color: #2a5298;
        }

        .company-location {
            font-size: 0.9em;
            color: #7f8c8d;
        }

        .position {
            font-weight: 600;
            color: #34495e;
            margin: 5px 0;
            font-size: 1.1em;
        }

        .period {
            color: #7f8c8d;
            font-size: 0.9em;
            font-style: italic;
        }

        .responsibilities {
            list-style: none;
            padding-left: 0;
        }

        .responsibilities li {
            margin-bottom: 8px;
            padding-left: 20px;
            position: relative;
        }

        .responsibilities li::before {
            content: "•";
            color: #2a5298;
            font-weight: bold;
            position: absolute;
            left: 0;
        }

        /* Formação acadêmica */
        .education-item {
            margin-bottom: 15px;
        }

        .education-title {
            font-weight: 600;
            color: #2c3e50;
        }

        .education-detail {
            color: #7f8c8d;
            font-size: 0.95em;
        }

        /* Grid de habilidades */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .skill-category {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            border-left: 4px solid #2a5298;
        }

        .skill-category h4 {
            color: #1e3c72;
            margin-bottom: 10px;
            font-size: 1.1em;
        }

        .skill-category ul {
            list-style: none;
        }

        .skill-category li {
            margin-bottom: 5px;
            padding-left: 15px;
            position: relative;
            color: #34495e;
        }

        .skill-category li::before {
            content: "▹";
            color: #2a5298;
            position: absolute;
            left: 0;
        }

        /* Certificações */
        .certifications {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .cert-item {
            background: #f8f9fa;
            padding: 10px 15px;
            border-radius: 20px;
            font-size: 0.95em;
            border: 1px solid #e0e0e0;
            color: #2c3e50;
        }

        /* Informações adicionais */
        .additional-info {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin-top: 20px;
        }

        .additional-info p {
            margin-bottom: 10px;
            padding-left: 20px;
            position: relative;
        }

        .additional-info p::before {
            content: "✓";
            color: #2a5298;
            position: absolute;
            left: 0;
            font-weight: bold;
        }

        /* Responsividade */
        @media (max-width: 768px) {
            .header {
                padding: 30px 20px;
            }

            .content {
                padding: 30px 20px;
            }

            .name {
                font-size: 2em;
            }

            .contact-info {
                flex-direction: column;
                gap: 10px;
            }

            .experience-header {
                flex-direction: column;
                gap: 5px;
            }

            .skills-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Impressão */
        @media print {
            body {
                background: white;
                padding: 0;
            }

            .container {
                box-shadow: none;
                border-radius: 0;
            }

            .header {
                background: #1e3c72;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
